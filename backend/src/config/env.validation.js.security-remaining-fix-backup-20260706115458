const { URL } = require("node:url");

function cleanValue(value) {
  return String(value ?? "").trim();
}

function isPlaceholder(value) {
  const normalized = cleanValue(value).toLowerCase();

  if (!normalized) return true;

  return [
    "undefined",
    "null",
    "none",
    "changeme",
    "change_me",
    "example",
    "your_value_here",
    "replace_me",
  ].includes(normalized) ||
    /^(your|paste|replace|change|add|example)[\s_-]/i.test(normalized) ||
    /^<.*>$/.test(normalized);
}

function createConfigError(errors) {
  const messages = Array.isArray(errors) ? errors : [errors];

  const error = new Error(
    [
      "",
      "==============================================",
      "BACKEND STARTUP BLOCKED: Environment validation failed",
      "==============================================",
      ...messages.map((message) => `• ${message}`),
      "",
      "Fix backend/.env or deployment environment variables, then restart.",
      "==============================================",
    ].join("\n")
  );

  error.code = "ENVIRONMENT_VALIDATION_FAILED";
  return error;
}

function requireEnv(name, errors, minLength = 1) {
  const value = cleanValue(process.env[name]);

  if (isPlaceholder(value)) {
    errors.push(`${name} is missing or contains a placeholder value.`);
    return "";
  }

  if (value.length < minLength) {
    errors.push(`${name} must contain at least ${minLength} characters.`);
    return "";
  }

  return value;
}

function validateUrl(name, value, errors, options = {}) {
  if (!value) return null;

  let parsedUrl;

  try {
    parsedUrl = new URL(value);
  } catch {
    errors.push(`${name} must be a valid absolute URL.`);
    return null;
  }

  if (!["http:", "https:"].includes(parsedUrl.protocol)) {
    errors.push(`${name} must begin with http:// or https://.`);
    return null;
  }

  const isLocalhost = [
    "localhost",
    "127.0.0.1",
    "::1",
  ].includes(parsedUrl.hostname);

  const isProduction =
    cleanValue(process.env.NODE_ENV).toLowerCase() === "production";

  if (isProduction && (parsedUrl.protocol !== "https:" || isLocalhost)) {
    errors.push(
      `${name} must use a public HTTPS URL when NODE_ENV=production.`
    );
  }

  if (options.youtubeCallback) {
    if (parsedUrl.pathname !== "/api/youtube/callback") {
      errors.push(
        `${name} must end exactly with /api/youtube/callback.`
      );
    }

    if (parsedUrl.search || parsedUrl.hash) {
      errors.push(
        `${name} must not contain query parameters or a URL hash.`
      );
    }
  }

  return parsedUrl;
}

function getFirebaseServiceAccount() {
  const rawJson = cleanValue(process.env.FIREBASE_SERVICE_ACCOUNT_JSON);
  const base64Json = cleanValue(
    process.env.FIREBASE_SERVICE_ACCOUNT_JSON_BASE64
  );

  if (rawJson && base64Json) {
    throw createConfigError(
      "Use only one Firebase credential variable: FIREBASE_SERVICE_ACCOUNT_JSON or FIREBASE_SERVICE_ACCOUNT_JSON_BASE64."
    );
  }

  if (!rawJson && !base64Json) {
    throw createConfigError(
      "Set FIREBASE_SERVICE_ACCOUNT_JSON or FIREBASE_SERVICE_ACCOUNT_JSON_BASE64."
    );
  }

  if (rawJson && isPlaceholder(rawJson)) {
    throw createConfigError(
      "FIREBASE_SERVICE_ACCOUNT_JSON contains a placeholder value."
    );
  }

  if (base64Json && isPlaceholder(base64Json)) {
    throw createConfigError(
      "FIREBASE_SERVICE_ACCOUNT_JSON_BASE64 contains a placeholder value."
    );
  }

  let jsonText = rawJson;

  if (base64Json) {
    try {
      jsonText = Buffer.from(base64Json, "base64").toString("utf8");
    } catch {
      throw createConfigError(
        "FIREBASE_SERVICE_ACCOUNT_JSON_BASE64 could not be decoded."
      );
    }
  }

  let serviceAccount;

  try {
    serviceAccount = JSON.parse(jsonText);
  } catch {
    throw createConfigError(
      "Firebase service account is not valid JSON."
    );
  }

  const requiredFields = [
    "project_id",
    "client_email",
    "private_key",
  ];

  const missingFields = requiredFields.filter(
    (field) => !cleanValue(serviceAccount?.[field])
  );

  if (missingFields.length) {
    throw createConfigError(
      `Firebase service account is missing: ${missingFields.join(", ")}.`
    );
  }

  if (
    serviceAccount.type &&
    cleanValue(serviceAccount.type) !== "service_account"
  ) {
    throw createConfigError(
      "Firebase credential type must be service_account."
    );
  }

  return {
    ...serviceAccount,
    private_key: String(serviceAccount.private_key).replace(/\\n/g, "\n"),
  };
}

function validateEnvironment() {
  const errors = [];

  const supabaseUrl = requireEnv("SUPABASE_URL", errors, 10);
  requireEnv("SUPABASE_SERVICE_ROLE_KEY", errors, 16);

  requireEnv("GROQ_API_KEY", errors, 10);
  requireEnv("YOUTUBE_DATA_API_KEY", errors, 10);

  requireEnv("GOOGLE_CLIENT_ID", errors, 10);
  requireEnv("GOOGLE_CLIENT_SECRET", errors, 8);

  const googleRedirectUri = requireEnv(
    "GOOGLE_REDIRECT_URI",
    errors,
    10
  );

  requireEnv("YOUTUBE_OAUTH_STATE_SECRET", errors, 32);
  requireEnv("YOUTUBE_TOKEN_ENCRYPTION_KEY", errors, 32);

  const frontendUrl = requireEnv("FRONTEND_URL", errors, 10);

  validateUrl("SUPABASE_URL", supabaseUrl, errors);
  validateUrl("FRONTEND_URL", frontendUrl, errors);

  validateUrl(
    "GOOGLE_REDIRECT_URI",
    googleRedirectUri,
    errors,
    { youtubeCallback: true }
  );

  let firebaseServiceAccount = null;

  try {
    firebaseServiceAccount = getFirebaseServiceAccount();
  } catch (error) {
    errors.push(
      String(error.message || "Firebase service-account validation failed.")
        .replace(/=+/g, "")
        .replace("BACKEND STARTUP BLOCKED: Environment validation failed", "")
        .replace(
          "Fix backend/.env or deployment environment variables, then restart.",
          ""
        )
        .trim()
    );
  }

  if (errors.length) {
    throw createConfigError(errors);
  }

  return {
    firebaseServiceAccount,
  };
}

module.exports = {
  validateEnvironment,
  getFirebaseServiceAccount,
};